<div id="Div_RouteMachines" class="col-md-12">
    <div class="table-responsive table-he-180 w-100 ">
        <table class="table table-sm table-bordered mb-3 text-center tableFixHead" id="RouteMachinesTable">
            <thead class="  table-info th-sti">
                <tr class="table-border-bottom">
                    <th width="50%">Machine</th>
                    <th>Floor to Floor time</th>
                    <th>Status</th>
                    <th width="5%"></th>
                </tr>
            </thead>
            <tbody>
            </tbody>
        </table>
    </div>
    <div>
        <label class="form-label col-md-6 mb-1 mt-3">No of Machines that can run this operation simultaneously </label>
        <div class="col-md-3 mb-2">
            <input class="form-control form-control-sm mt-3" type="number" title="For Line Balancing reasons if more than 1 machine has to run the Operation Step .... indicate the number of Machines that need to run simultaneously. Those many machines or more have to be added to the list " data-plugin="tippy" data-tippy-placement="top">
        </div>
        <!-- ============ -->
        <div class="col-md-3 mt-3 mb-1 text-end">
            <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#add-machine" title="" data-plugin="tippy" data-tippy-placement="top">Add Machine</button>
        </div>
    </div>
</div>

<template id="RouteMachineTemplate">
    <tr>
        <td data-key="machine">{machine}</td>
        <td data-key="ftoftime">{ftoftime}</td>
        <td data-key="status">---</td>
        <td>
            <div class="dropdown float-center">
                <a href="#" class="dropdown-toggle arrow-none card-drop" data-bs-toggle="dropdown" aria-expanded="false"><i class="mdi mdi-dots-vertical"></i></a>
                <div class="dropdown-menu dropdown-menu-end">
                    <!-- item-->
                    <a href="javascript:void(0);" data-makefromid="{routeMachineId}" data-bs-toggle="modal" data-bs-target="#add-machine" class="dropdown-item">Edit</a>
                    <!-- item-->
                    <a href="javascript:void(0);" data-makefromid="{routeMachineId}" data-bs-toggle="modal" data-bs-target="#add-machine" class="dropdown-item">Delete</a>
                </div>
            </div>
        </td>
    </tr>
</template>